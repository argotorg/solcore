import std.{*};
pragma no-patterson-condition ;
pragma no-coverage-condition ;
pragma no-bounded-variable-condition ;
  function zero () {
    return 0;
  }

function one() {
    return 1 + zero() ;
  }

function two () {
  let x = zero();
  x = x + one();
  x =  x + x ;
  return x;
}

contract Plus {
  function main() -> word { return two() + two(); }
}
