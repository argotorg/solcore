// Class-qualified named calls should disambiguate instances sharing a label.

data Bool = True | False;

forall a . class a : Foo {
  function run(x : a) -> Bool;
}

forall a . class a : Bar {
  function run(x : a) -> Bool;
}

instance [shared] word : Foo {
  function run(x : word) -> Bool {
    return True;
  }
}

instance [shared] word : Bar {
  function run(x : word) -> Bool {
    return False;
  }
}

contract NamedInstClassQualified {
  function main() -> Bool {
    let x : Bool = Foo.run@{shared}(1);
    let y : Bool = Bar.run@{shared}(1);
    return y;
  }
}
