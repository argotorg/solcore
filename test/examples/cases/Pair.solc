  function fst (x) {
    match x {
    | (a,_) => return a;
    }
  }

  forall a b . function snd(x : (a,b)) -> b {
    match x {
    | (_,b) => return b;
    }
  }

  function uncurry(f,x) {
    match x {
    | (a,b) => return f(a,b);
    }
  }

  function snds (p1, p2) {
    match p1, p2 {
    | (a,b) , (c,d) => return (b,d);
    }
  }

  function curry(f,x,y) {
    return f((x,y)) ;
  }
