contract EitherModule {
  data memory(a) = memory(word);
  data Either(a,b) = Left(a) | Right(b);
  data List(a) = Nil | Cons(a, memory(List(a)));

  function lefts(xs : List(Either(word,word))) -> List(word) {
    match xs {
    | List.Nil => return List.Nil ;
    | List.Cons(y,ys) =>
      match y {
      | Either.Left(z) => return List.Cons(z,lefts(ys)) ;
      | Either.Right(z) => return lefts(ys) ;
      }
    }
  }

  function main() -> word { return 0; }
}
