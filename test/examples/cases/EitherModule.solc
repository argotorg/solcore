contract EitherModule {
  data Either(a,b) = Left(a) | Right(b);
  data List(a) = Nil | Cons(a,List(a));

  function lefts(xs) {
    match xs {
    | List.Nil => return List.Nil ;
    | List.Cons(y,ys) =>
      match y {
      | Either.Left(z) => return List.Cons(z,lefts(ys)) ;
      | Either.Right(z) => return lefts(ys) ;
      }
    }
  }

}
