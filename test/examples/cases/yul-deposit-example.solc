import std.{*};

function deposit(pubkey: memory(string), withdrawal_credentials: memory(string), signature: memory(string), deposit_data_root: uint256) -> () {
    let msg_value : uint256 = msg.value();
}

contract Foo {
   function main () -> () {
      deposit(memory(0), memory(0), memory(0), uint256(2));
   }
}
