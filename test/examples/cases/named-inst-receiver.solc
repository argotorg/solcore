// Named instance dispatch should also work through receiver syntax.

data Bool = True | False;

forall a . class a : Eq {
  function eq(x : a, y : a) -> Bool;
}

instance [myEq] word : Eq {
  function eq(x : word, y : word) -> Bool {
    match primEqWord(x, y) {
    | 0 => return False;
    | _ => return True;
    }
  }
}

contract NamedInstReceiver {
  function main() -> Bool {
    return 1.eq@{myEq}(1);
  }
}
