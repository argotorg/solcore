class a: Enum {
  function fromEnum(a) -> word;
}

data Food = Curry | Beans | Other;

instance Food : Enum {
  function fromEnum(x : Food) {
     match x {
       | Food.Curry => return 1;
       | Food.Beans => return 2;
       | Food.Other => return 3;
     }
  }
}

contract Food {
  function main() {
    return Enum.fromEnum(Food.Beans);
  }
}
