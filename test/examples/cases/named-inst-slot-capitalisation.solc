// Lowercase slot aliases should not become ambiguous when two class names only
// differ by capitalisation; exact class-name slots remain available.

forall a . class a : Eq {
  function upperScore(x : a) -> word;
}

forall a . class a : eq {
  function lowerScore(x : a) -> word;
}

forall a . a : Eq, a : eq => function useBoth(x : a) -> word {
  return Eq.upperScore(x);
}

instance [upperEq] word : Eq {
  function upperScore(x : word) -> word {
    return 1;
  }
}

instance [lowerEq] word : eq {
  function lowerScore(x : word) -> word {
    return 2;
  }
}

contract NamedInstSlotCapitalisation {
  function main() -> word {
    return useBoth@{Eq = upperEq, eq = lowerEq}(1);
  }
}
