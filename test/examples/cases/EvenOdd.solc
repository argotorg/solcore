contract EvenOdd {
  data Nat = Zero | Succ(Nat);
  data Bool = False | True;

  function even (n) {
    match n {
    | Nat.Zero => return Bool.True;
    | Nat.Succ(m) => return odd(m);
    }
  }

  function odd(n) {
    match n {
    | Nat.Zero => return Bool.False;
    | Nat.Succ(m) => return even(m);
    }
  }
}
