
forall a . class  a : Neg {
   function neg(x:a) -> a;
}

data B = F | T;

instance B : Neg {
  function neg (x : B) -> B {
    match x {
    | B.F => return B.T;
    | B.T => return B.F;
    }
  }
}

function fst (p) {
  match p {
  | (x,y) => return x;
  }
}

function snd(p) {
  match p {
    | (x,y) => return y;
  }
}


forall a b . a : Neg, b : Neg => instance (a,b):Neg {
  function neg(p : (a,b)) -> (a,b) {
    return (Neg.neg (fst(p)), Neg.neg(snd (p)));
  }
}

contract NegPair {

 function bnot(x) {
   match x {
     | B.T => return B.F;
     | B.F => return B.T;
   }
}

 function fromB(b) {
  match b  {
    | B.F => return 0;
    | B.T => return 1;
  }
}

 function main() { return  fromB(fst(Neg.neg((B.F,B.T)))); }
}
