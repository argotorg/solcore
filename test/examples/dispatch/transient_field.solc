import std.{*};
import std.tstorage.{*};
import std.dispatch.{*};

// Demonstrates the `transient` storage-location keyword on a contract field:
// `bal : transient uint256` selects EVM transient storage for the field, so
// `set`/`get` lower to tstore/tload instead of sstore/sload.
contract TransientField {
  bal : transient uint256;

  public function set(v: uint256) -> () {
    bal = v;
  }

  public function get() -> uint256 {
    return bal;
  }
}
