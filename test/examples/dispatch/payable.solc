import std.{*};
import std.dispatch.{*};

contract PayableTest {
    constructor() {}

    public payable function deposit() -> uint256 {
        return msg.value();
    }

    public function balance() -> uint256 {
        let value;
        assembly {
            value := selfbalance()
        }
        return uint256(value);
    }

    payable fallback() -> () {
        if (msg.value() == uint256(0)) {
            revertLit("fallback-was-called-no-value");
        }
    }
}
