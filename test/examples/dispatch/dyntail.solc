import std.{*};
import std.dispatch.{*};
pragma no-patterson-condition ;
pragma no-coverage-condition ;
pragma no-bounded-variable-condition ;

// Pins the (currently incorrect) behaviour of std/dispatch.solc when a
// dynamic argument's tail is truncated in calldata. do_exec only checks
// the head size (see the `TODO: calldatasize checks for dynamic types`
// in std/dispatch.solc) so a caller can pass a valid offset that points
// past the end of calldata without the dispatcher reverting. abi_decode
// then reads zeros for the missing length and content.
//
// When the dynamic-tail check is added upstream, the expected status
// for these cases should flip from success to failure (ABIInputTruncated
// = 0x08638556).

contract DynTail {
  constructor() {}

  function echoBytes(b : memory(bytes)) -> memory(bytes) {
    return b;
  }

  function echoString(s : memory(string)) -> memory(string) {
    return s;
  }
}
