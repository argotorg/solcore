data Food = Curry | Beans | Other;
data CFood = Red(Food) | Green(Food) | Nocolor;



  function fromEnum(x : CFood) {
     match x {
       | CFood.Red(Food.Curry) => return 1;
       | CFood.Green(Food.Beans) => return 42;
       | _ => return 3;
     }
  }


contract Food {
  function id(x) {
    return(x);
  }

  function main() {
  return fromEnum(id(CFood.Green(Food.Beans)));
  }
}
