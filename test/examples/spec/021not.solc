contract Not {
  data Bool = False | True;

  function main() -> word {
    return fromBool(bnot(Bool.False));
  }

  function fromBool(b : Bool) -> word {
    match(b) {
      | Bool.False => return 0;
      | Bool.True  => return 1;
    }
  }

  function bnot(b : Bool) -> Bool {
    match b {
      | Bool.False => return Bool.True;
      | Bool.True => return Bool.False;
    }
  }
}
