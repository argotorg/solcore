contract Dwarves {
  data Dwarf = Doc | Grumpy | Sleepy | Bashful | Happy | Sneezy | Dopey;


  function fromEnum(c) {
    match c {
      | Dwarf.Doc      => return 1;
      | Dwarf.Grumpy   => return 2;
      | Dwarf.Sleepy   => return 3;
      | Dwarf.Bashful  => return 4;
      | Dwarf.Happy    => return 5;
      | _              => return 0;
    }
  }

  function main() { return fromEnum(Dwarf.Happy); }
}
